<UserControl x:Class="FinTrack.Views.DashboardView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- PAGE TITLE -->
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- SUMMARY CARDS ROW -->
            <TextBlock Text="Overview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">

                <!-- Income Card -->
                <Border Background="#FF2ECC71" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Total Income" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtIncome" Text="$0.00" Foreground="White"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Expenses Card -->
                <Border Background="#FFE74C3C" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Total Expenses" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtExpenses" Text="$0.00" Foreground="White"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Balance Card -->
                <Border x:Name="balanceCard" Background="#FF3498DB" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Current Balance" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtBalance" Text="$0.00" Foreground="White"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- BUDGET ALERTS -->
            <TextBlock Text="Budget Alerts" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border x:Name="alertBorder" Background="#FFFFF3CD" CornerRadius="8"
                    Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="txtAlerts" TextWrapping="Wrap"
                               Foreground="#FF856404" FontSize="13"/>
                </StackPanel>
            </Border>
            <Border x:Name="noAlertBorder" Background="#FFD4EDDA" CornerRadius="8"
                    Padding="15" Margin="0,0,0,20">
                <TextBlock Text="✔ All budgets are within limits." Foreground="#FF155724" FontSize="13"/>
            </Border>

            <!-- BUDGET OVERVIEW -->
            <TextBlock Text="Budget Overview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Background="#FFF8F9FA" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <ItemsControl x:Name="lstBudgets">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <!-- Category and amount labels -->
                                <Grid>
                                    <TextBlock Text="{Binding Category}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="13">
                                        <Run Text="{Binding Spent, StringFormat='${0:F2}'}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding Limit, StringFormat='${0:F2}'}"/>
                                    </TextBlock>
                                </Grid>
                                <!-- Progress Bar -->
                                <ProgressBar Value="{Binding Spent}" Maximum="{Binding Limit}"
                                             Height="12" Margin="0,4,0,0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Foreground" Value="#FF2ECC71"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFE74C3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- RECENT TRANSACTIONS -->
            <TextBlock Text="Recent Transactions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Background="#FFF8F9FA" CornerRadius="8" Padding="15">
                <ItemsControl x:Name="lstRecentTransactions">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:MM/dd/yyyy}'}"
                                           Foreground="Gray" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="13"/>
                                <TextBlock Grid.Column="2" Text="{Binding Category}"
                                           Foreground="Gray" FontSize="12"/>
                                <TextBlock Grid.Column="3" HorizontalAlignment="Right"
                                           FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFE74C3C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                    <Setter Property="Foreground" Value="#FF2ECC71"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Amount, StringFormat='${0:F2}'}"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>