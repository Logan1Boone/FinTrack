<UserControl x:Class="FinTrack.Views.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Reports &amp; Export" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <Button Content="Generate Report" Width="170" HorizontalAlignment="Left" Margin="0,10,0,5"
                    Click="GenerateReport_Click"/>
            <Button Content="Export CSV" Width="170" HorizontalAlignment="Left" Margin="0,5,0,5"
                    Click="ExportCsv_Click"/>
            <Button Content="Export PDF" Width="170" HorizontalAlignment="Left" Margin="0,5,0,5"
                    Click="ExportPdf_Click"/>

            <TextBlock x:Name="txtReportOutput" Margin="0,20,0,0" FontSize="14" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>