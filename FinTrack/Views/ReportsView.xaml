<UserControl x:Class="FinTrack.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <Grid Margin="20"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

            <!-- CHARTS: NEVER Auto -->
            <RowDefinition Height="400"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="400"/>

            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

            <!-- PAGE TITLE -->
            <TextBlock Grid.Row="0"
                       Text="Reports &amp; Export"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- DATE RANGE FILTER -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="Filter by Date Range"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="dpStartDate" Width="150" Margin="0,0,16,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="dpEndDate" Width="150" Margin="0,0,16,0"/>
                    <Button Content="Generate Report" Width="150" Click="GenerateReport_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- REPORT SUMMARY -->
            <Border Grid.Row="2"
                    x:Name="pnlSummary"
                    Background="#FFF0F4FF"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Report Summary"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtSummary"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- PIE CHART LABEL -->
            <TextBlock Grid.Row="3"
                       Text="Spending by Category"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <!-- PIE CHART -->
                <Grid Grid.Row="4"
                    Background="White"
                    Margin="0,0,0,20">

                    <lvc:PieChart x:Name="pieChart"
                                LegendPosition="Hidden"/>
                </Grid>
            <!-- LINE CHART LABEL -->
            <TextBlock Grid.Row="5"
                       Text="Monthly Expenses"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <!-- LINE CHART -->
            <Grid Grid.Row="6"
                Background="White"
                Margin="0,0,0,20">

                <lvc:CartesianChart x:Name="lineChart"/>
            </Grid>

            <!-- EXPORT -->
            <TextBlock Grid.Row="7"
                    Text="Export"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,0,0,10"/>

            <StackPanel Grid.Row="8" Orientation="Horizontal">
                <Button Content="Export CSV"
                        Width="150"
                        Margin="0,0,10,0"
                        Click="ExportCsv_Click"/>
                <Button Content="Export PDF Report"
                        Width="150"
                        Click="ExportPdf_Click"/>
            </StackPanel>

            <!-- STATUS MESSAGE -->
            <TextBlock Grid.Row="9"
                    x:Name="txtStatus"
                    Margin="0,15,0,0"
                    FontSize="13"
                    Foreground="Green"
                    TextWrapping="Wrap"/>
        </Grid>
        </ScrollViewer>
</UserControl>