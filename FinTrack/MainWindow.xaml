<Window x:Class="FinTrack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FinTrack.Views"
        Title="FinTrack Finance Manager" Height="650" Width="1100">

    <Grid>
        <TabControl>

            <!-- DASHBOARD -->
            <TabItem Header="Dashboard">
                <views:DashboardView x:Name="Dashboard"/>
            </TabItem>

            <!-- TRANSACTIONS -->
            <TabItem Header="Transactions">
                <views:TransactionsView/>
            </TabItem>

            <!-- BUDGETS -->
            <TabItem Header="Budgets">
                <views:BudgetView/>
            </TabItem>

            <!-- REPORTS -->
            <TabItem Header="Reports">
                <views:ReportsView/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>